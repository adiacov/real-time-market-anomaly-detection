# Environment variables for the real-time market anomaly detection application
# Copy this file to .env and fill in the actual values

# API key for Finnhub (used for fetching stock data)
FINNHUB_API_KEY=<finnhub api key>

# API key for Twelve Data (used for fetching stock data)
TWELVEDATA_API_KEY=<twelvedata api key>

# LLM configuration for Anomaly Agent
# Choose one provider; supports remote LLMs or local Ollama
# Only one LLM provider is used at a time

# API key for OpenAI (leave empty if not using)
OPENAI_API_KEY=

# API key for Anthropic (leave empty if not using)
ANTHROPIC_API_KEY=

# API key for Google Gemini (leave empty if not using)
GEMINI_API_KEY=
